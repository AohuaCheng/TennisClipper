*.cpython-*.pyc

# Virtual environments
.venv/
venv/
env/
uv.lock

# Build artifacts
*.egg-info/
build/
dist/

# Test / cache
.pytest_cache/
.coverage

# Generated media files (exports, proxies, screenshots)
*.mp4
*.avi
*.mov
*.mkv
*.flv
*.wmv
*.webm
*.gif
*.png
