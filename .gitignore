# Local sessions: ignore all subdirectories but keep this README
/sessions/*/
!/sessions/README.md

# Legacy session patterns (kept for safety)
/test_session_*/
/*_session_*/
/work/
/export/
/.clips/
/clips/

# Local session config (root level only)
/config.yaml

# Downloaded model weights (local only)
yolov8n.pt
models/

# ML datasets: keep schemas/README/manifests/benchmarks JSON; ignore media
/datasets/player_actions/raw_crops/**
!/datasets/player_actions/raw_crops/.gitkeep
/datasets/ball_detection/frames/**
!/datasets/ball_detection/frames/.gitkeep
/datasets/benchmarks/.cache/
